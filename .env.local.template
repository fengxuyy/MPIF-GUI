# ORCID OAuth Configuration
# Register a free public API client at:
#   - Sandbox:    https://sandbox.orcid.org/developer-tools
#   - Production: https://orcid.org/developer-tools
#
# Set the Redirect URI in your ORCID client to exactly:
#   http://localhost:5173/orcid-callback   (for local dev)
#   https://your-domain.com/orcid-callback (for production)

VITE_ORCID_CLIENT_ID=APP-XXXXXXXXXXXXXXXXX

# Redirect URI must match what is registered in your ORCID client
VITE_ORCID_REDIRECT_URI=http://localhost:5173/orcid-callback

# Set to "true" to use sandbox.orcid.org, "false" for production orcid.org
VITE_ORCID_SANDBOX=true
